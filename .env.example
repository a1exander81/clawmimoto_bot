# ============================================
# Claw_Rise_bot — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================

# ---------- Exchange (BingX) ----------
BINGX_API_KEY=your_bingx_api_key_here
BINGX_API_SECRET=your_bingx_api_secret_here
BINGX_TEST_MODE=false  # set to true for dry-run (no real orders)

# ---------- AI / DeepSeek ----------
# Primary AI engine: DeepSeek for SMC+ICT analysis.
# OpenAI-compatible endpoint: https://api.deepseek.com
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
# Models: deepseek-v4-flash (default), deepseek-v4-pro (heavier reasoning).
# Legacy aliases deepseek-chat / deepseek-reasoner deprecated 2026-07-24.
DEEPSEEK_MODEL_FAST=deepseek-v4-flash
DEEPSEEK_MODEL_DEEP=deepseek-v4-flash
# Timeouts in seconds. DEEPSEEK_TIMEOUT controls the HTTP-level timeout
# in integrations/deepseek.py; FAST/DEEP_TIMEOUT control ai_scan retries.
DEEPSEEK_TIMEOUT=15
DEEPSEEK_FAST_TIMEOUT=10
DEEPSEEK_DEEP_TIMEOUT=30
# Filter thresholds for ai_scan_pairs.
DEEPSEEK_CONFIDENCE_THRESHOLD=65   # 0-100; setups below are skipped
DEEPSEEK_MIN_RRR=2.0               # min risk/reward ratio; setups below are skipped

# ---------- Telegram Bot ----------
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
TELEGRAM_ADMIN_ID=7093901111  # your Telegram user ID (Rentardio)

# ---------- X / Twitter ----------
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret
TWITTER_ACCESS_TOKEN=your_access_token
TWITTER_ACCESS_SECRET=your_access_secret

# ---------- Risk Parameters ----------
# Leverage: default 50X, adjustable ±10% via Telegram buttons.
# Hard cap: 100X (values >100X will be rejected).
# Warnings: UI will alert if leverage drops below 50X (low‑leverage caution) or exceeds 100X (blocked).
DEFAULT_LEVERAGE=50
MAX_LEVERAGE=100
DEFAULT_MARGIN_PERCENT=1.5  # 1-2% range; can be overridden via UI ±10%
MAX_TRADES_PER_DAY=3
SL_TOLERANCE_MIN=10  # % stop-loss floor
SL_TOLERANCE_MAX=20  # % stop-loss ceiling
DEFAULT_RRR=2.0
LEVERAGE_WARNING_THRESHOLD_LOW=50
LEVERAGE_WARNING_THRESHOLD_HIGH=100

# ---------- Trading Sessions (Asia/Singapore) ----------
# Optimal 5M scalping windows (converted from UTC to SGT = UTC+8)
# 
# NYSE (New York):
#   Standard Time (Nov–Mar): 14:30 UTC → 22:30 SGT
#   Daylight Saving (Mar–Nov): 13:30 UTC → 21:30 SGT
#   Prime scalping window: 14:30–15:30 UTC → 22:30–23:30 SGT (STD) or 21:30–22:30 SGT (DST)
#   Note: DST starts second Sunday in March, ends first Sunday in November.
#
# LSE (London):
#   Open: 08:00 UTC → 16:00 SGT
#   Prime scalping window: 08:00–09:30 UTC → 16:00–17:30 SGT
#
# TSE (Tokyo):
#   Morning open: 00:00 UTC → 08:00 SGT
#   Morning scalping: 00:00–01:00 UTC → 08:00–09:00 SGT
#   Afternoon open: 03:30 UTC → 11:30 SGT
#   Afternoon scalping: 03:30–04:30 UTC → 11:30–12:30 SGT
#
# We schedule auto trades to fire at the START of each prime window:
SESSION_NY_OPEN=21:30   #夏季/DST (13:30 UTC → 21:30 SGT)
#SESSION_NY_OPEN=22:30  #冬季/STD (14:30 UTC → 22:30 SGT) — uncomment based on current DST
SESSION_TOKYO_MORNING_OPEN=08:00
SESSION_TOKYO_AFTERNOON_OPEN=11:30
SESSION_LONDON_OPEN=16:00

# ---------- Database ----------
DATABASE_URL=sqlite:///data/claw_rise.db

# ---------- Logging ----------
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR
LOG_DIR=logs

# ---------- WebUI ----------
WEBUI_HOST=0.0.0.0
WEBUI_PORT=8000

# ---------- Health / Supervisor ----------
HEALTH_HOST=0.0.0.0
HEALTH_PORT=8080
SUPERVISOR_RESTART_ATTEMPTS=3
SUPERVISOR_ALERT_RETRY_DELAY=300  # seconds between repeated failure alerts
